# ══════════════════════════════════════════════════════════════════
# persona-lens — .env.example
# Copy to .env and fill in your values. Never commit .env to git.
# ══════════════════════════════════════════════════════════════════

# ── HuggingFace ───────────────────────────────────────────────────
# Required for downloading gated models (Mistral-7B-Instruct-v0.3).
# Get your token at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# ── Model Identifiers ─────────────────────────────────────────────
# Override defaults in configs/presets.py if needed.
EMBEDDING_MODEL=sentence-transformers/multi-qa-mpnet-base-dot-v1
LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# ── Qdrant ────────────────────────────────────────────────────────
# Leave blank to use in-memory mode (default for POC).
# Set to a remote URL for persistent/production deployments.
QDRANT_URL=
QDRANT_API_KEY=

# ── Experiment Storage ────────────────────────────────────────────
# Directory where ExperimentStore saves JSON outputs.
# Defaults to outputs/experiments/ relative to repo root.
EXPERIMENT_OUTPUT_DIR=outputs/experiments

# ── Evaluation ────────────────────────────────────────────────────
# Number of questions to evaluate per persona per run.
# Override per-run via --n_eval_questions CLI flag.
N_EVAL_QUESTIONS=80

# ── LLM Judge ─────────────────────────────────────────────────────
# Set to false to skip LLM judge and use semantic fallbacks only.
# Useful for fast iteration runs without full judge overhead.
USE_LLM_JUDGE=true

# ── GPU / Device ──────────────────────────────────────────────────
# auto   → use CUDA if available, else CPU
# cuda   → force GPU (will error if unavailable)
# cpu    → force CPU (slow, not recommended for 7B models)
DEVICE=auto

# ── Logging ───────────────────────────────────────────────────────
# Options: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
